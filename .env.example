# MySQL Connection (Hostinger / Dockploy)
# 1. log in to your Hostinger Control Panel
# 2. Go to Databases -> MySQL Databases
# 3. Copy 'MySQL Host' (e.g., sql123.main-hosting.eu)
# 4. Copy 'MySQL Database' (e.g., u123456789_dbname)
# 5. Copy 'MySQL User' (e.g., u123456789_user)

MYSQL_HOST=sql123.main-hosting.eu
MYSQL_PORT=3306
MYSQL_USER=u123456789_user
MYSQL_PASSWORD=your_secure_password
MYSQL_DATABASE=u123456789_database
MYSQL_SSL=true # Recommended for external connections
JWT_SECRET=your_jwt_secret_key

